#!/usr/bin/env bash
set -euo pipefail

# ---------------------------------------------
# Configuration
# ---------------------------------------------
TARGET_HOST="planck-primary"
TARGET_DIR="/opt/pip-speed"
WRAPPER="pip-speed-wrapper.sh"

# ---------------------------------------------
# Validate wrapper exists
# ---------------------------------------------
if [[ ! -f "$WRAPPER" ]]; then
    echo "ERROR: wrapper script not found at: $WRAPPER"
    exit 1
fi

echo "==> Deploying iperf3 wrapper to $TARGET_HOST:$TARGET_DIR"

# ---------------------------------------------
# Preflight remote access and dependencies
# ---------------------------------------------
echo "==> Verifying SSH access and remote dependencies"
ssh -o BatchMode=yes "$TARGET_HOST" 'command -v iperf3 >/dev/null 2>&1 && command -v jq >/dev/null 2>&1'

# ---------------------------------------------
# Copy wrapper to remote /tmp
# ---------------------------------------------
scp "$WRAPPER" "$TARGET_HOST:/tmp/pip-speed-wrapper.sh"

# ---------------------------------------------
# Move into place on remote host
# ---------------------------------------------
ssh "$TARGET_HOST" << EOF
set -euo pipefail

# Ensure target directory exists
sudo mkdir -p "$TARGET_DIR"

# Move wrapper into place
sudo mv /tmp/pip-speed-wrapper.sh "$TARGET_DIR/pip-speed-wrapper.sh"

# Ensure executable
sudo chmod 755 "$TARGET_DIR/pip-speed-wrapper.sh"

echo "wrapper installed at $TARGET_DIR/pip-speed-wrapper.sh"
EOF

echo "==> Deployment complete."
echo "==> Ensure Telegraf has IPERF3_ENDPOINTS set (comma-separated host[:port] list)."
