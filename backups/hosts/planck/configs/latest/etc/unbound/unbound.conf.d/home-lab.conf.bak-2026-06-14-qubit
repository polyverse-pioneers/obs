server:
  interface: 127.0.0.1
  interface: 192.168.40.10

  # Emit query/reply activity into journald so observability can summarize top
  # query names and upstream DNS destinations without raw packet capture.
  use-syslog: yes
  log-queries: yes
  log-replies: yes

  access-control: 127.0.0.0/8 allow
  access-control: 192.168.10.0/24 allow
  access-control: 192.168.20.0/24 allow
  access-control: 192.168.30.0/24 allow
  access-control: 192.168.40.0/24 allow
  access-control: 192.168.99.0/24 allow

  private-domain: "home.spinriko.com"
  private-domain: "home.polyversepioneers.org"
  private-domain: "home.polyversepioneers.com"

  local-zone: "home.spinriko.com." static
