  local-data: "quantum.home.spinriko.com. 300 IN A 192.168.99.10"
  local-data: "hawking.home.spinriko.com. 300 IN A 192.168.99.200"
  local-data: "dirac.home.spinriko.com. 300 IN A 192.168.10.1"
